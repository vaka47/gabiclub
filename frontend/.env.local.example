## Frontend -> Backend API base URL
# Point to Django's /api root. Example values:
# - Local dev:  http://localhost:8000/api
# - Production (same domain proxy): https://gabiclub.ru/api
# - Production (separate API host): https://api.gabiclub.ru/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

## Staging safety:
# Set this to 1 on test/staging so the frontend never falls back to production API
# when NEXT_PUBLIC_API_URL is missing or misconfigured.
# NEXT_PUBLIC_DISABLE_PROD_API_FALLBACK=1

## Search indexing:
# Set this to 1 on test/staging to emit robots noindex/nofollow headers and robots.txt.
# NEXT_PUBLIC_SITE_NOINDEX=1

## Theming images (optional)
# Club photo used under the inline lead form overlay on the hero section.
# Can be absolute URL (https://...) or a path returned by the API like /media/... (will be resolved).
# Example: https://images.unsplash.com/photo-1515516969-d4008cc6241a?auto=format&fit=crop&w=1400&q=80
NEXT_PUBLIC_CLUB_PHOTO=

# Subtle snow photo for the site-wide background. Should be calm/minimal.
# Example: https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=1920&auto=format
NEXT_PUBLIC_SNOW_BG=/site-bg.jpg
# Skip hitting remote API during static build (Vercel) and use local mocks
# Set to 1 in Production/Preview if your API may return 5xx during build
SKIP_API_AT_BUILD=1

## Hero background slideshow (up to three photos)
# Provide absolute URLs or /media/... paths to show under the gradient on the hero.
# Tip: use the provided portraits. Example:
# NEXT_PUBLIC_HERO_BG_1=https://example.com/media/portrait-1.jpg
# NEXT_PUBLIC_HERO_BG_2=https://example.com/media/portrait-2.jpg
# NEXT_PUBLIC_HERO_BG_3=https://example.com/media/portrait-3.jpg
NEXT_PUBLIC_HERO_BG_1=/gabi-min.jpg
NEXT_PUBLIC_HERO_BG_2=/hero-1-min.jpg
NEXT_PUBLIC_HERO_BG_3=/hero-2-min.jpg

## Wordmark image (PNG/SVG). Put file into /public and set the path or use absolute URL
# Example: /gabi-wordmark.png
# Option: text wordmark with Halenoir font (preferred).
# If you still want to use an image, uncomment the line below and change the code to render it.
# NEXT_PUBLIC_GABI_WORDMARK=/gabi-wordmark.svg

# Header compact logo (square or circle-friendly). Put file into /public and set path.
# Example: /gabi-logo.png
# If not set, a "G" letter will be shown.
NEXT_PUBLIC_LOGO=/gabi-logo.png

## Debugging: log media URL resolution and image load errors (server + client)
# Set to 1 to enable verbose [media] logs in console/server logs
# NEXT_PUBLIC_DEBUG_MEDIA=1
